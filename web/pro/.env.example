# GoalIQ Pro (web/pro) — tarvittavat secretit. KOPIOI .env:ksi lokaalisti TAI
# lisää hostin secret-dashboardiin (Streamlit Cloud: st.secrets / Render: env).
# ÄLÄ KOSKAAN committaa oikeita arvoja.

# --- Supabase (sama projekti kuin mobiili) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon public key>
# Service-avain: subscription-upsert (Streamlit-palvelin + webhook). Palvelin-only.
SUPABASE_SERVICE_KEY=<service_role key>

# --- Stripe (sama tili; ALOITA test-modella sk_test_...) ---
STRIPE_SECRET_KEY=sk_test_...
# Luo Stripe Dashboardissa 2 uutta hintaa tuotteelle "GoalIQ Pro (web)":
#   - 25 EUR one-time  -> STRIPE_PRICE_SEASON_ID
#   - 3.99 EUR/kk rec. -> STRIPE_PRICE_MONTHLY_ID
STRIPE_PRICE_SEASON_ID=price_...
STRIPE_PRICE_MONTHLY_ID=price_...
# Webhook-secret backendin /api/webhook/stripe-web-endpointille (Render env,
# EI tänne Streamlitiin): STRIPE_WEB_WEBHOOK_SECRET=whsec_...

# --- Appi ---
# Checkout-redirectien base-URL (lokaali test: http://localhost:8501)
APP_BASE_URL=http://localhost:8501
