# Datavalimuisti — voi olla iso, ei kuulu repoon
# Huom: /data/ alussa = vain projektin juuren data/, EI src/data/
# /data/* ignoroi sisällön mutta sallii poikkeukset (vendoroitu WC-data #79).
raw_data/
/data/*
# Poikkeukset: vendoroitu martj42-maaotteludata (CC0) kuuluu repoon — Render
# buildaa gitistä, ei live-pullia ajossa.
!/data/international_results.csv
!/data/international_results.README.md
# Esirakennettu WC-malli (#79) — vendoroitu, ladataan ajossa (ei fittiä Renderillä).
!/data/wc_model.json
# Vendoroitu World Football Elo -snapshot (#79 konfederaatio-kalibrointi).
!/data/elo_ratings.csv
# Tarkkuus-track-record (#100): ajastettu putki ylläpitää, Render lukee gitistä.
!/data/prediction_log.json
!/data/accuracy.json
# FPL Phase 0 -projektio: ajastettu refresh ylläpitää, Render lukee gitistä (/api/fantasy).
!/data/fpl_projections_phase0.json
# FPL Phase 1 xP -projektio: sama refresh-konventio (/api/fantasy/xp).
!/data/fpl_xp_projections.json
# FPL Phase 1b: manuaaliset konteksti-yliajot (versioitu input, builderit lukevat).
!/data/fpl_manual_overrides.csv
downloaded_files/
~/soccerdata/

